diff --git a/3rd_party/llvm-project/22.x/patches/lld-coff-thinlto-weak-alias.patch b/3rd_party/llvm-project/22.x/patches/lld-coff-thinlto-weak-alias.patch
new file mode 100644
--- /dev/null
+++ b/3rd_party/llvm-project/22.x/patches/lld-coff-thinlto-weak-alias.patch
@@ -0,0 +1,42 @@
+diff --git a/lld/COFF/LTO.h b/lld/COFF/LTO.h
+--- a/lld/COFF/LTO.h
++++ b/lld/COFF/LTO.h
+@@ -29,6 +29,7 @@ namespace lld::coff {
+ class BitcodeFile;
+ class InputFile;
+ class COFFLinkerContext;
++class Symbol;
+ 
+ void thinLTOCreateEmptyIndexFiles(COFFLinkerContext &ctx);
+ 
+@@ -51,5 +52,6 @@ private:
+   std::unique_ptr<llvm::raw_fd_ostream> indexFile;
+   llvm::DenseSet<StringRef> thinIndices;
++  llvm::DenseSet<Symbol *> prevailingWeakAliases;
+ 
+   std::string getThinLTOOutputFile(StringRef path);
+   llvm::lto::Config createConfig();
+diff --git a/lld/COFF/LTO.cpp b/lld/COFF/LTO.cpp
+--- a/lld/COFF/LTO.cpp
++++ b/lld/COFF/LTO.cpp
+@@ -199,7 +199,19 @@ void BitcodeCompiler::add(BitcodeFile &f) {
+     // flags an undefined in IR with a definition in ASM as prevailing.
+     // Once IRObjectFile is fixed to report only one symbol this hack can
+     // be removed.
+-    r.Prevailing = !objSym.isUndefined() && sym->getFile() == &f;
++    //
++    // COFF weak externals are represented as Undefined symbols whose
++    // weakAlias exists only in this lld-link process. During an index-only
++    // link, select one weak indirect definition so its backend object can
++    // recreate the weak external for the final lld-link process.
++    auto *u = dyn_cast<Undefined>(sym);
++    bool prevailingWeakAlias =
++        ctx.config.thinLTOIndexOnly && objSym.isWeak() &&
++        objSym.isIndirect() && u && u->weakAlias &&
++        prevailingWeakAliases.insert(sym).second;
++
++    r.Prevailing = !objSym.isUndefined() &&
++                   (prevailingWeakAlias || sym->getFile() == &f);
+     r.VisibleToRegularObj = sym->isUsedInRegularObj;
+     if (r.Prevailing)
+       undefine(sym);
