+def _strip_level_from_flags(flags, strip_level):
+    """Returns the last rustc strip level in a list of command-line flags."""
+    if type(flags) != "list":
+        return strip_level
+
+    expect_codegen_option = False
+    for flag in flags:
+        if type(flag) != "string":
+            expect_codegen_option = False
+            continue
+
+        option = None
+        if expect_codegen_option:
+            option = flag
+            expect_codegen_option = False
+        elif flag in ("-C", "--codegen"):
+            expect_codegen_option = True
+        elif flag.startswith("-C"):
+            option = flag[2:]
+        elif flag.startswith("--codegen="):
+            option = flag[len("--codegen="):]
+
+        if option != None and option.startswith("strip="):
+            strip_level = option[len("strip="):]
+
+    return strip_level
+
+def _effective_strip_level(compilation_mode, rust_flags, collected_extra_flags, authored_rustc_flags):
+    """Returns the effective strip level using rustc's last-option-wins order."""
+    strip_level = compilation_mode.strip_level
+    strip_level = _strip_level_from_flags(rust_flags, strip_level)
+    strip_level = _strip_level_from_flags(collected_extra_flags, strip_level)
+    return _strip_level_from_flags(authored_rustc_flags, strip_level)
+
+def _strip_option(strip_level, target_os, target_abi, crate_type):
+    """Maps a rustc strip level to the equivalent rust-objcopy option."""
+    if strip_level == "none" or target_abi == "msvc":
+        return None
+    if strip_level == "debuginfo":
+        return "--strip-debug"
+    if strip_level == "symbols":
+        if target_os in ("darwin", "macos") and crate_type != "bin":
+            return "--discard-all"
+        return "--strip-all"
+    fail("Unsupported rustc strip level: {}".format(strip_level))
 
